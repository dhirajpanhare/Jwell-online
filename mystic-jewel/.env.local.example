# ============================================================================
# Mystic Jewel Frontend - Environment Variables
# ============================================================================

# ============================================================================
# API Configuration
# ============================================================================
# Backend API URL - where the Express API is running
VITE_API_BASE_URL=http://localhost:3000/api/v1.0

# ============================================================================
# Cloudinary Configuration (for file uploads)
# ============================================================================
# 1. Create a free account at https://cloudinary.com
# 2. Get Cloud Name from Dashboard > Settings
# 3. Create an upload preset:
#    - Go to Settings > Upload
#    - Add new preset (unsigned mode for frontend)
#    - Copy the preset name
#
# NOTE: Frontend uses UNSIGNED uploads (no API secret needed)
#       API Key is optional and only used for metadata retrieval
#
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-upload-preset
VITE_CLOUDINARY_API_KEY=your-api-key

# ============================================================================
# Application Configuration
# ============================================================================
VITE_APP_NAME=Mystic Jewel
VITE_APP_DESCRIPTION=Premium Artificial Jewellery
VITE_APP_VERSION=1.0.0

# ============================================================================
# Feature Flags (optional)
# ============================================================================
# Enable/disable features during development
VITE_ENABLE_ADMIN_PANEL=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_MODE=false
