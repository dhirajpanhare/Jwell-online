# DynamicApi-Express Environment Variables

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=DynamicApiDb

# Server
PORT=3000
NODE_ENV=development

# JWT
# JWT_SECRET is kept for backward compatibility — prefer JWT_SECRETS for multi-project setups
JWT_SECRET=your-secret-key-min-32-characters-long
JWT_EXPIRATION=3600

# ─────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION
# ─────────────────────────────────────────────────────────────────────────────
# AUTH_MODE controls the authentication strategy:
#
#   none    — No authentication (default for development)
#   token   — Static token(s) only  → set STATIC_TOKENS below
#   jwt     — JWT only              → set JWT_SECRETS below
#   hybrid  — Both static + JWT     → use during migration
#
AUTH_MODE=none

# Hardcoded static tokens (comma-separated). Clients send: Authorization: Bearer <token>
# Generate a strong value: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Remove this once all clients switch to JWT.
STATIC_TOKENS=

# JWT secrets from external auth APIs (comma-separated, one per project).
# Dynamic API never generates tokens — it only validates them.
# Your auth API signs tokens with HS256; add that secret here.
JWT_SECRETS=

# External auth service URL (optional — takes priority over AUTH_MODE)
# If set, every token is forwarded to this URL for validation.
# POST with Authorization: Bearer <token>  →  expects { "status": true|false }
# Leave empty to use AUTH_MODE instead.
AUTH_SERVICE_URL=

LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
# EMAIL_PROVIDER determines which email service to use: GMAIL, MAILGUN, SENDGRID, or SMTP
# Default: GMAIL
EMAIL_PROVIDER=GMAIL

# GMAIL Configuration
# 1. Enable 2FA on your Google account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-character app password below (no spaces)
GMAIL_USER=dhirajpanhare08@gmail.com
GMAIL_APP_PASSWORD=orryxsirlwmwzqon

# MAILGUN Configuration (alternative)
# 1. Create account at https://mailgun.com
# 2. Get SMTP credentials from mailgun dashboard
MAILGUN_EMAIL=noreply@mg.yourdomain.com
MAILGUN_PASSWORD=your-mailgun-smtp-password
MAILGUN_SMTP_HOST=smtp.mailgun.org

# SENDGRID Configuration (alternative)
# 1. Create account at https://sendgrid.com
# 2. Generate API key from Settings > API Keys
SENDGRID_API_KEY=your-sendgrid-api-key

# Generic SMTP Configuration (any SMTP provider)
# For Gmail SMTP:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=dhirajpanhare08@gmail.com
SMTP_PASSWORD=orryxsirlwmwzqon

# Sender email address (appears in "From" field)
SENDER_EMAIL=dhirajpanhare08@gmail.com

# ─────────────────────────────────────────────────────────────────────────────
# OTP CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
