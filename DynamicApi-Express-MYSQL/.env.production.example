# DynamicApi-Express-MySQL Production Environment Variables
# IMPORTANT: Copy this file to .env and fill in actual values before deployment

# Database Configuration
DB_HOST=your_production_db_host
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_secure_db_password
DB_NAME=your_production_database

# Server Configuration
PORT=3000
NODE_ENV=production

# JWT Configuration — CRITICAL: Generate strong secret before production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRY=24h

# Authentication Mode (recommended: jwt for production)
AUTH_MODE=jwt

# CORS Configuration - Add your production domain
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Logging
LOG_LEVEL=error

# API Configuration
API_VERSION=v1.0
API_PREFIX=/api

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=GMAIL

# GMAIL Configuration
GMAIL_USER=noreply@yourdomain.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Sender email address
SENDER_EMAIL=noreply@yourdomain.com

# ─────────────────────────────────────────────────────────────────────────────
# CLOUDINARY CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─────────────────────────────────────────────────────────────────────────────
# RAZORPAY PAYMENT GATEWAY CONFIGURATION (PRODUCTION)
# ─────────────────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=your_live_key_secret
RAZORPAY_WEBHOOK_SECRET=your_live_webhook_secret
